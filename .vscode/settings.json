{
    "cortex-debug.liveWatchRefreshRate": 500,
    "cortex-debug.armToolchainPath.windows": "${env:ARMGCC_DIR}",
    "cortex-debug.gdbPath": "${env:ARMGCC_DIR}/arm-none-eabi-gdb.exe",
    "cortex-debug.variableUseNaturalFormat": true,
    "files.associations": {
        "clock_config.h": "c",
        "stm32f4xx_interrupts.h": "c",
        "stm32f407xx.h": "c",
        "string.h": "c",
        "cmsis_os.h": "c",
        "stdint.h": "c",
        "stddef.h": "c",
        "system_stm32f4xx.h": "c",
        "core_cm4.h": "c",
        "cmsis_compiler.h": "c"
    },
    "editor.formatOnSave": true,
    "editor.suggest.showInlineDetails": true,
    "makefile.makefilePath": "${workspaceFolder}/Makefile",
}